PORT=5001
MONGO_URI=<your-mongodb-uri>
OPENAI_API_KEY=<your-openai-api-key>
CHAT_ENCRYPTION_PASSPHRASE=<your-encryption-passphrase>
JWT_SECRET=<your-jwt-secret>
# Comma-separated allowed origins for CORS (frontend, backend)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Upload/Model settings
MAX_CONTENT_LENGTH=10485760
MODEL_TIMEOUT_SECONDS=12
ML_RATE_LIMIT_MAX=120
ML_RATE_LIMIT_WINDOW_SECONDS=60
# Set to 0 on Windows to avoid reloader socket issues in development
FLASK_USE_RELOADER=0
OPENAI_API_KEY = "your-openai-api-key"
MONGO_URI = "your-mongodb-uri"
CHAT_ENCRYPTION_PASSPHRASE = "set-a-strong-passphrase"
# OR use Fernet key directly:
# CHAT_ENCRYPTION_KEY = "your-fernet-key"
ALLOWED_ORIGINS = "http://localhost:5173"
MAX_CONTENT_LENGTH = 10485760
MODEL_TIMEOUT_SECONDS = 12
TRANSCRIPTION_TIMEOUT_SECONDS = 20
MODEL_EXECUTOR_WORKERS = 4
ML_RATE_LIMIT_MAX = 120
ML_RATE_LIMIT_WINDOW_SECONDS = 60